# .editorconfig — cross-editor formatting standard
#
# Reference: https://editorconfig.org
# Adopted in P3.7 of Phase 3 (environment hardening).
#
# Most editors (VS Code, GoLand, vim, emacs, etc.) read this
# automatically. Plugin may be required for some editors.

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Go uses tabs (gofmt convention)
[*.go]
indent_style = tab
indent_size = 4

# Makefile requires tabs (POSIX requirement)
[Makefile]
indent_style = tab
indent_size = 4

[*.mk]
indent_style = tab
indent_size = 4

# Rust uses 4-space indent
[*.rs]
indent_style = space
indent_size = 4

# Markdown allows trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false

# Shell scripts: 2-space convention
[*.sh]
indent_style = space
indent_size = 2

# YAML / TOML / JSON: 2-space
[*.{yml,yaml,toml,json,jsonc}]
indent_style = space
indent_size = 2
