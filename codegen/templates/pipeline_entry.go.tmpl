{
	family:       "{{.Spec.Family.Name}}",
	consumerName: "{{.Derived.ConsumerName}}",
	inserterName: "{{.Derived.InserterName}}",
	table:        "{{.Spec.Writer.Table}}",
	insertSQL:    "{{.Derived.InsertSQL}}",
	consumerSpec: adapternats.{{.Derived.ConsumerSpecFunc}}(),
	isEnabled:    func(p settings.PipelineConfig) bool { return p.{{.Derived.IsEnabledMethod}}("{{.Spec.Family.Name}}") },
	startConsumer: func(natsURL string, spec adapternats.ConsumerSpec, inserterPID *actor.PID, tracker *healthz.Tracker, logger *slog.Logger, actorCtx *actor.Context) (io.Closer, error) {
		consumer := adapternats.{{.Derived.NewConsumerFunc}}(natsURL, spec, reg.{{.Derived.RegistryField}},
			func(event {{.Spec.Domain.EventPackage}}.{{.Spec.Domain.EventType}}) {
				if tracker != nil {
					tracker.RecordEvent()
					tracker.Counter("events_received").Add(1)
				}
				actorCtx.Send(inserterPID, insertRowMsg{row: {{.Spec.Writer.Mapper}}(event)})
			},
			logger,
		)
		return consumer, consumer.Start()
	},
},
