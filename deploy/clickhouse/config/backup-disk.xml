<clickhouse>
    <!-- Backup disk configuration for native BACKUP/RESTORE commands.
         The path /backups/ is bind-mounted from the host via docker-compose. -->
    <storage_configuration>
        <disks>
            <backups>
                <type>local</type>
                <path>/backups/</path>
            </backups>
        </disks>
    </storage_configuration>
    <backups>
        <allowed_disk>backups</allowed_disk>
        <allowed_path>/backups/</allowed_path>
    </backups>
</clickhouse>
