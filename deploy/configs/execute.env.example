# Execute service venue credentials template.
# Copy to execute.env and fill in real values.
# NEVER commit execute.env — it is excluded by .gitignore.
#
# Convention: MF_VENUE_{VENUE_TYPE}_{CREDENTIAL_NAME}
# Example for a hypothetical exchange:
# MF_VENUE_BINANCE_API_KEY=your_api_key_here
# MF_VENUE_BINANCE_API_SECRET=your_api_secret_here
