{
  "uid": "mf-gateway-health",
  "title": "Gateway Health",
  "tags": ["market-foundry", "gateway"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "",
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate by method (req/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (rate(marketfoundry_http_requests_total[5m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Gateway GET p99 latency (F3 SLI)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (path, le) (rate(marketfoundry_http_request_duration_seconds_bucket{method=\"GET\"}[5m])))",
          "legendFormat": "{{path}}"
        },
        {
          "refId": "B",
          "expr": "vector(0.2)",
          "legendFormat": "SLO target 200ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "title": "Error rate by status_code class (req/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_code) (rate(marketfoundry_http_requests_total{status_code=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top routes by request rate — last 5m",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (method, path) (rate(marketfoundry_http_requests_total[5m])))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "F3 burn-rate (Observing)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 6},
      "targets": [
        {"refId": "A", "expr": "slo:store_read_latency:burn_rate_5m", "legendFormat": "5m"},
        {"refId": "B", "expr": "slo:store_read_latency:burn_rate_30m", "legendFormat": "30m"},
        {"refId": "C", "expr": "slo:store_read_latency:burn_rate_1h", "legendFormat": "1h"},
        {"refId": "D", "expr": "slo:store_read_latency:burn_rate_6h", "legendFormat": "6h"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 6},
              {"color": "red", "value": 14.4}
            ]
          }
        }
      }
    }
  ]
}
