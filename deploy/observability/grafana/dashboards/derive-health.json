{
  "uid": "mf-derive-health",
  "title": "Derive Health",
  "tags": ["market-foundry", "derive"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "",
  "panels": [
    {
      "id": 1,
      "title": "Derive consumer throughput (msg/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (consumer) (rate(marketfoundry_consumer_messages_total{consumer=~\"derive.*\", outcome=\"delivered\"}[5m]))",
          "legendFormat": "{{consumer}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Derive processing duration p99 (F2 SLI)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (consumer, le) (rate(marketfoundry_consumer_processing_duration_seconds_bucket{consumer=~\"derive.*\"}[5m])))",
          "legendFormat": "{{consumer}} p99"
        },
        {
          "refId": "B",
          "expr": "vector(0.5)",
          "legendFormat": "SLO target 500ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "title": "Derive consumer lag (messages)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (consumer) (marketfoundry_consumer_lag_messages{consumer=~\"derive.*\"})",
          "legendFormat": "{{consumer}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Derive outcome distribution — last 5m",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (increase(marketfoundry_consumer_messages_total{consumer=~\"derive.*\"}[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "F2 burn-rate (Observing)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "marketfoundry-prometheus"},
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 6},
      "targets": [
        {"refId": "A", "expr": "slo:derive_latency:burn_rate_5m", "legendFormat": "5m"},
        {"refId": "B", "expr": "slo:derive_latency:burn_rate_30m", "legendFormat": "30m"},
        {"refId": "C", "expr": "slo:derive_latency:burn_rate_1h", "legendFormat": "1h"},
        {"refId": "D", "expr": "slo:derive_latency:burn_rate_6h", "legendFormat": "6h"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 6},
              {"color": "red", "value": 14.4}
            ]
          }
        }
      }
    }
  ]
}
