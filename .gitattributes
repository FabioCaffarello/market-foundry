# .gitattributes — git-level file handling
#
# Adopted in P3.7 of Phase 3 (environment hardening).
#
# - Forces LF line endings for text files (cross-platform consistency).
# - Marks binary files (prevents accidental diff/merge corruption).
# - Marks generated files (excluded from GitHub language stats).
# - Documentation hints for linguist (GitHub repo language detection).

# Default: auto-detect text, normalize to LF
* text=auto eol=lf

# Source code: explicit LF
*.go        text eol=lf
*.rs        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.proto     text eol=lf

# Makefile preserves tabs
Makefile    text eol=lf
*.mk        text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.tgz       binary

# Generated files (excluded from linguist language stats)
go.sum              linguist-generated=true
**/go.sum           linguist-generated=true
Cargo.lock          linguist-generated=true
**/Cargo.lock       linguist-generated=true
package-lock.json   linguist-generated=true

# Documentation (linguist hints)
docs/**         linguist-documentation
*.md            linguist-documentation
LICENSE         linguist-documentation
SECURITY.md     linguist-documentation
README.md       linguist-documentation
